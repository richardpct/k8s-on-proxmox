applications:
  external-secrets:
    namespace: argocd
    annotations:
      argocd.argoproj.io/sync-wave: "-5"
    finalizers:
    - resources-finalizer.argocd.argoproj.io
    project: default
    sources:
      - repoURL: https://charts.external-secrets.io
        chart: external-secrets
        targetRevision: 2.5.0
        helm:
          valueFiles:
            - $values/external-secrets/values.yaml
      - repoURL: https://github.com/richardpct/argocd-apps.git
        targetRevision: install-mimir
        ref: values
    destination:
      server: https://kubernetes.default.svc
      namespace: external-secrets
    syncPolicy:
      automated:
        prune: false
        selfHeal: false
      syncOptions:
      - CreateNamespace=true
      - ServerSideApply=true
    revisionHistoryLimit: null
  ceph-csi:
    namespace: argocd
    additionalLabels: {}
    additionalAnnotations: {}
    finalizers:
    - resources-finalizer.argocd.argoproj.io
    project: default
    source:
      repoURL: https://github.com/richardpct/argocd-apps.git
      targetRevision: HEAD
      path: ceph-csi
      helm:
        valueFiles:
        - values.yaml
        parameters:
          - name: ceph-csi-cephfs.csiConfig[0].clusterID
            value: ${ceph_cluster_id}
          - name: ceph-csi-cephfs.storageClass.clusterID
            value: ${ceph_cluster_id}
    destination:
      server: https://kubernetes.default.svc
      namespace: ceph-csi
    syncPolicy:
      automated:
        prune: false
        selfHeal: false
      syncOptions:
      - CreateNamespace=true
    revisionHistoryLimit: null
  metrics-server:
    namespace: argocd
    additionalLabels: {}
    additionalAnnotations: {}
    finalizers:
    - resources-finalizer.argocd.argoproj.io
    project: default
    source:
      repoURL: https://github.com/richardpct/argocd-apps.git
      targetRevision: HEAD
      path: metrics-server
      helm:
        valueFiles:
        - values.yaml
    destination:
      server: https://kubernetes.default.svc
      namespace: metrics
    syncPolicy:
      automated:
        prune: false
        selfHeal: false
      syncOptions:
      - CreateNamespace=true
    revisionHistoryLimit: null
    info:
    - name: url
      value: https://github.com/kubernetes-sigs/metrics-server
